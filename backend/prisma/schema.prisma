generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id                    String    @id @default(uuid())
  slug                  String    @unique

  // Identity
  name                  String
  type                  String    @default("trail") // trail | route | marathon
  description           String?   @db.Text
  date                  DateTime?
  location              String    @default("Alger")

  // Branding
  primaryColor          String    @default("#C42826")
  logoPath              String?
  coverImagePath        String?

  // Social links
  facebookUrl           String?
  instagramUrl          String?
  tiktokUrl             String?
  websiteUrl            String?

  // Contact CTA
  contactEmail          String?
  contactPhone          String?
  contactLabel          String?

  // Distances — JSON array of {name, elevation?, timeLimit?}
  distances             Json      @default("[]")

  // Runner levels — JSON array of strings, e.g. ["Débutant", "Confirmé", "Elite"]
  runnerLevels          Json      @default("[\"Débutant\", \"Confirmé\", \"Elite\"]")

  // Registration control
  registrationOpen      Boolean   @default(true)
  registrationDeadline  DateTime?
  maxCapacity           Int?
  autoCloseOnExhaustion Boolean   @default(true)

  // Bib config
  bibStart              Int       @default(101)
  bibEnd                Int       @default(1500)
  bibPrefix             String?
  bibRangeLocked        Boolean   @default(false)

  // Pricing
  priceInCentimes       Int       @default(200000)
  photoPackPrice        Int?

  // Activatable optional fields — "off" | "optional" | "required"
  optionalFields        Json      @default("{}")

  // Terms/rules text
  termsText             String?   @db.Text

  // Status
  active                Boolean   @default(false)
  status                String    @default("upcoming") // upcoming | active | archived

  // Relations
  registrations         Registration[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([active])
  @@index([status])
}

model Registration {
  id                        String    @id @default(uuid())

  // Event
  eventId                   String
  event                     Event     @relation(fields: [eventId], references: [id])

  // Informations personnelles
  lastName                  String
  firstName                 String
  birthDate                 DateTime
  gender                    String    // "Homme" | "Femme"
  nationality               String
  phoneCountryCode          String
  phoneNumber               String
  phone                     String    // E.164
  email                     String

  // Residence
  countryOfResidence        String
  wilaya                    String?
  commune                   String?
  ville                     String?

  // Urgence
  emergencyPhoneCountryCode String
  emergencyPhoneNumber      String
  emergencyPhone            String    // E.164

  // Preferences
  tshirtSize                String    // S | M | L | XL | XXL
  runnerLevel               String    // Debutant | Confirme | Elite

  // Declarations
  declarationFit            Boolean   @default(false)
  declarationRules          Boolean   @default(false)
  declarationImage          Boolean   @default(false)
  termsAccepted             Boolean   @default(false)

  // Attribution
  bibNumber                 Int?      @unique
  qrToken                   String?   @unique

  // Paiement
  paymentStatus             String    @default("pending") // pending | processing | success | failed | manual
  paymentMethod             String?   // CIB / EDAHABIA / null
  orderNumber               String?   // our 8-char order ID
  transactionId             String?   @unique
  transactionNumber         String?
  approvalCode              String?
  paymentAmount             Int       @default(200000) // centimes
  paymentDate               DateTime?
  cardPan                   String?   // last 4 digits from SATIM

  // Statut
  status                    String    @default("en_attente") // en_attente | distribue
  distributedAt             DateTime?
  distributedBy             String?

  // Source
  source                    String    @default("public") // public | admin
  createdBy                 String?

  // Optional fields (activated per event)
  selectedDistance          String?
  medicalCertificatePath   String?
  club                     String?
  licenseNumber            String?
  bestPerformance          String?   // H:MM:SS
  previousParticipations   Int?
  shuttle                  Boolean?
  bloodType                String?   // A+ | A- | B+ | B- | AB+ | AB- | O+ | O-
  photoPack                Boolean?

  // Relations
  emailsSent                EmailLog[]

  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([email, eventId])
  @@index([eventId])
  @@index([status])
  @@index([paymentStatus])
  @@index([lastName, firstName])
  @@index([bibNumber])
}

model AdminUser {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String?
  role            String    @default("admin") // super_admin | admin | scanner
  active          Boolean   @default(true)
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  inviteAccepted  Boolean   @default(false)
  otpCode         String?
  otpExpiresAt    DateTime?
  otpAttempts     Int       @default(0)
  createdAt       DateTime  @default(now())
}

model ScannerSession {
  id             String   @id @default(uuid())
  operatorId     String
  operatorName   String
  registrationId String
  bibNumber      Int
  runnerName     String
  scannedAt      DateTime @default(now())
  method         String   @default("qr") // qr | manual
}

model EmailLog {
  id             String       @id @default(uuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id])
  templateName   String       // confirmation | invitation
  sentAt         DateTime     @default(now())
  sentBy         String       // "system" or admin username
}

model EmailTemplate {
  id      String @id @default(uuid())
  name    String @unique // confirmation | invitation
  subject String
  body    String // HTML with {{prenom}}, {{dossard}} etc.
}

model ActivityLog {
  id            String   @id @default(uuid())
  action        String
  adminUsername String
  targetType    String?  // registration | event | admin_user
  targetId      String?
  details       Json?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([adminUsername])
}
