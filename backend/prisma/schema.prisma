generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id   String @id @default(uuid())
  slug String @unique

  // Identity
  name        String
  type        String    @default("trail") // trail | route | marathon
  description String?   @db.Text
  date        DateTime?
  location    String    @default("Alger")

  // Branding
  primaryColor   String  @default("#C42826")
  logoPath       String?
  coverImagePath String?

  // Social links
  facebookUrl  String?
  instagramUrl String?
  tiktokUrl    String?
  websiteUrl   String?

  // Contact CTA
  contactEmail String?
  contactPhone String?
  contactLabel String?

  // Distances — JSON array of {name, elevation?, timeLimit?}
  distances Json @default("[]")

  // Runner levels — JSON array of strings, e.g. ["Débutant", "Confirmé", "Elite"]
  runnerLevels Json @default("[\"Débutant\", \"Confirmé\", \"Elite\"]")

  // Registration control
  registrationOpen      Boolean   @default(true)
  registrationDeadline  DateTime?
  maxCapacity           Int?
  autoCloseOnExhaustion Boolean   @default(true)

  // Volunteer ("Bénévoles") module — when true, public can submit a volunteer
  // application via /benevoles/<eventSlug>. Independent of registrationOpen.
  volunteersOpen Boolean @default(false)

  // Bib config
  bibStart          Int     @default(101)
  bibEnd            Int     @default(1500)
  bibManualUpperEnd Int? // optional ceiling for the upper manual band (bibEnd+1..bibManualUpperEnd)
  bibPrefix         String?
  bibRangeLocked    Boolean @default(false)

  // Pricing
  priceInCentimes Int  @default(200000)
  photoPackPrice  Int?

  // Activatable optional fields — "off" | "optional" | "required"
  optionalFields Json @default("{}")

  // FAQ — JSON array of {question, answer}
  faq Json @default("[]")

  // Terms/rules text
  termsText String? @db.Text

  // Status
  active Boolean @default(false)
  status String  @default("upcoming") // upcoming | active | archived

  // Relations
  registrations         Registration[]
  satimReconciliations  SatimReconciliation[]
  lateRegistrationLinks LateRegistrationLink[]
  volunteers            Volunteer[]
  campaigns             CommunicationCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([status])
}

model Registration {
  id String @id @default(uuid())

  // Event
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  // Informations personnelles
  lastName         String
  firstName        String
  birthDate        DateTime
  gender           String // "Homme" | "Femme"
  nationality      String
  phoneCountryCode String
  phoneNumber      String
  phone            String // E.164
  email            String

  // Residence
  countryOfResidence String
  wilaya             String?
  commune            String?
  ville              String?

  // Urgence
  emergencyPhoneCountryCode String
  emergencyPhoneNumber      String
  emergencyPhone            String // E.164

  // Preferences
  tshirtSize  String // S | M | L | XL | XXL
  runnerLevel String // Debutant | Confirme | Elite

  // Declarations
  declarationFit   Boolean @default(false)
  declarationRules Boolean @default(false)
  declarationImage Boolean @default(false)
  termsAccepted    Boolean @default(false)

  // Attribution
  bibNumber Int?
  qrToken   String? @unique

  // Paiement
  paymentStatus     String    @default("pending") // pending | processing | success | failed | manual | refunded
  paymentMethod     String? // CIB / EDAHABIA / null
  orderNumber       String? // our 8-char order ID
  transactionId     String?   @unique
  transactionNumber String?
  approvalCode      String?
  paymentAmount     Int       @default(200000) // centimes
  paymentDate       DateTime?
  refundedAt        DateTime? // set when admin initiates refund via Coureur drawer (paymentStatus → 'refunded')
  cardPan           String? // last 4 digits from SATIM

  // Statut
  status        String    @default("en_attente") // en_attente | distribue
  distributedAt DateTime?
  distributedBy String?

  // Proxy pickup — populated only when a third party collected the bib on race day.
  pickedUpAt               DateTime?
  pickedUpByName           String?
  pickedUpByPhone          String?
  pickedUpByCin            String? // text CIN number (optional)
  pickedUpByCinPhotoPath   String? // server-relative path, served via auth endpoint
  pickedUpByRelation       String? // conjoint | ami | famille | autre
  pickedUpByRegistrationId String?
  pickedUpByRegistration   Registration?  @relation("BibPickupProxy", fields: [pickedUpByRegistrationId], references: [id], onDelete: SetNull)
  pickupsMade              Registration[] @relation("BibPickupProxy")

  // Event-day check-in (additional event after distribution; independent of `status`)
  checkedInAt DateTime?
  checkedInBy String?

  // Source
  source    String  @default("public") // public | admin
  createdBy String?

  // Optional fields (activated per event)
  selectedDistance       String?
  medicalCertificatePath String?
  club                   String?
  licenseNumber          String?
  bestPerformance        String? // H:MM:SS
  previousParticipations Int?
  shuttle                Boolean?
  bloodType              String? // A+ | A- | B+ | B- | AB+ | AB- | O+ | O-
  photoPack              Boolean?

  // Relations
  emailsSent           EmailLog[]
  satimReconciliation  SatimReconciliation?
  lateRegistrationLink LateRegistrationLink?
  scannerSessions      ScannerSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, eventId])
  @@unique([bibNumber, eventId])
  @@index([eventId])
  @@index([status])
  @@index([paymentStatus])
  @@index([lastName, firstName])
  @@index([bibNumber])
  @@index([pickedUpByRegistrationId])
}

model AdminUser {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String?
  role            String    @default("admin") // super_admin | admin | scanner | reconciliation_specialist | admin_volunteers | team_leader_volunteers
  active          Boolean   @default(true)
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  inviteAccepted  Boolean   @default(false)
  otpCode         String?
  otpExpiresAt    DateTime?
  otpAttempts     Int       @default(0)
  createdAt       DateTime  @default(now())

  // Back-ref: volunteers assigned to this admin (only meaningful for team_leader_volunteers)
  assignedVolunteers Volunteer[] @relation("VolunteerAssignedTo")
}

model ScannerSession {
  id             String       @id @default(uuid())
  operatorId     String
  operatorName   String
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bibNumber      Int
  runnerName     String
  scannedAt      DateTime     @default(now())
  method         String       @default("qr") // qr | manual

  @@index([registrationId])
}

model EmailLog {
  id             String       @id @default(uuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id])
  templateName   String // confirmation | invitation
  sentAt         DateTime     @default(now())
  sentBy         String // "system" or admin username
}

model EmailTemplate {
  id      String @id @default(uuid())
  name    String @unique // confirmation | invitation
  subject String
  body    String // HTML with {{prenom}}, {{dossard}} etc.
}

model ActivityLog {
  id            String   @id @default(uuid())
  action        String
  adminUsername String
  targetType    String? // registration | event | admin_user | satim_reconciliation
  targetId      String?
  details       Json?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([adminUsername])
}

model SatimReconciliation {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  // SATIM row data (from Excel)
  paymentStatus  String // always 'Déposé' (validated on upload)
  orderNumber    String
  paymentDate    DateTime?
  depositDate    DateTime?
  approvedAmount Int // centimes (DZD × 100)
  cardholderName String
  cardPan        String // last 4 digits
  cardFirst4     String? // first 4 digits of the masked BIN (nullable for backward compat)

  // Token / outreach
  status          String    @default("pending") // pending | link_generated | submitted_matched | submitted_unmatched | expired | cancelled
  linkToken       String?   @unique
  linkExpiresAt   DateTime?
  linkSentToEmail String?
  linkSentAt      DateTime?

  // Resulting registration (filled on submit)
  registrationId    String?       @unique
  registration      Registration? @relation(fields: [registrationId], references: [id])
  enteredCardPan    String? // last 4 digits the runner typed (audit, even on mismatch)
  enteredCardFirst4 String? // first 4 digits the runner typed (audit, even on mismatch)

  // Audit
  uploadedBy String // admin username
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([eventId, orderNumber])
  @@index([eventId, status])
  @@index([linkToken])
}

model LateRegistrationLink {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  // Reserved bib (must be a gap inside the event auto range)
  bibNumber Int

  // Token / outreach
  token       String    @unique
  expiresAt   DateTime
  status      String    @default("pending") // pending | used | expired | cancelled
  sentToEmail String?
  sentAt      DateTime?

  // Linked when consumed (runner submits the form)
  registrationId String?       @unique
  registration   Registration? @relation(fields: [registrationId], references: [id])
  usedAt         DateTime?

  // Audit
  createdBy   String
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Only one pending reservation per (event, bib) — multiple historical rows
  // (used/expired/cancelled) for the same bib are allowed.
  @@unique([eventId, bibNumber, status])
  @@index([token])
  @@index([eventId, status])
}

model Volunteer {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  // Per-event volunteer identifier (e.g. "TMO4827" — event initials + 4 random digits)
  volunteerId String?

  // QR token (UUID) issued at validation. Encodes the URL to the public badge page.
  qrToken     String? @unique

  // Personal info
  lastName    String
  firstName   String
  email       String
  phone       String // E.164
  birthDate   DateTime?
  gender      String?
  nationality String?

  // Residence
  wilaya  String?
  commune String?

  // Free-text motivation / availability
  motivation String? @db.Text

  // Availability & skills
  availableRaceDay   Boolean @default(false) // ok to work race day
  canArriveEarly     Boolean @default(false) // ok to arrive before main shift (briefing + setup)
  previousExperience String? @db.Text // describes past events (empty = none)
  languagesSpoken    String? // free text, comma-separated
  canStandLongTime   Boolean @default(false) // can stand for long periods
  tshirtSize         String? // S | M | L | XL | XXL

  // Skills — JSON array of checked skills (e.g. ["Communication","Secourisme"])
  skills      Json?
  otherSkills String?

  // Emergency contact
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?

  // Required agreements (validated at submit; stored for audit)
  // Legacy two-box agreement (kept nullable for backwards compatibility with older
  // candidates that submitted before the consolidated règlement was introduced).
  agreedInstructions Boolean @default(false)
  agreedBriefing     Boolean @default(false)
  // Single consolidated règlement acknowledgment used by the current form.
  agreedRules        Boolean @default(false)

  // Uploaded files (relative paths under /uploads/volunteers/<eventId>/<id>/)
  cvPath String?
  idPath String?

  // Lifecycle
  status String @default("en_attente") // en_attente | interview_planned | validee | rejected

  // Interview workflow
  interviewSlots  Json? // Array of datetime ISO strings proposed by admin
  interviewSentAt DateTime?
  interviewSentTo String? // copy of email at time of send (audit)

  // Validation
  validatedAt DateTime?
  validatedBy String?

  // Rejection
  rejectedAt DateTime?
  rejectedBy String?

  // Assignment to a team leader (set by Admin Bénévoles on validated volunteers)
  assignedToId String?
  assignedTo   AdminUser? @relation("VolunteerAssignedTo", fields: [assignedToId], references: [id])
  assignedAt   DateTime?
  assignedBy   String?

  // Race-day check-in (via QR scan)
  checkedInAt DateTime?
  checkedInBy String?

  // Audit
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, volunteerId])
  @@unique([eventId, email])
  @@index([eventId, status])
  @@index([assignedToId])
}

model CommunicationCampaign {
  id      String  @id @default(uuid())
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])

  audienceType  String // 'custom' | 'all_runners' | 'all_volunteers' | 'volunteers_by_tlb'
  audienceParam String? // tlb userId for 'volunteers_by_tlb'; pipe-joined emails for 'custom'

  subject  String
  bodyHtml String  @db.Text
  bodyText String? @db.Text

  fromEmail String
  fromName  String?

  totalCount  Int @default(0)
  sentCount   Int @default(0)
  failedCount Int @default(0)

  status       String    @default("pending") // pending | running | done | failed
  startedAt    DateTime?
  completedAt  DateTime?
  errorSamples Json? // last 5 failure samples: [{email, message}]

  createdAt DateTime @default(now())
  createdBy String

  @@index([eventId, createdAt])
  @@index([status])
  @@index([createdBy])
}
